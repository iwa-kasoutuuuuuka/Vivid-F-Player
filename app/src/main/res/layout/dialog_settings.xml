<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_dialog_glass">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings_title"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/playback_speed"
        android:textColor="#BBBBBB"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/rg_speed"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.5x" android:textColor="#FFFFFF" />
        <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1.0x" android:textColor="#FFFFFF" android:checked="true" />
        <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1.5x" android:textColor="#FFFFFF" />
        <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2.0x" android:textColor="#FFFFFF" />
    </RadioGroup>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#33FFFFFF" android:layout_marginVertical="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/background_play"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/sw_background_play"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#333333" android:layout_marginVertical="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/repeat_mode"
            android:textColor="#BBBBBB"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/rg_repeat_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="OFF" android:textColor="#FFFFFF" />
            <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ONE" android:textColor="#FFFFFF" />
            <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ALL" android:textColor="#FFFFFF" />
        </RadioGroup>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/shuffle_play"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/sw_shuffle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/manage_folders"
        android:textColor="#BBBBBB"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_folders"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="160dp" />

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#33FFFFFF" android:layout_marginVertical="16dp" />

        <TextView
            android:id="@+id/btn_troubleshooting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/bg_troubleshooting_label"
            android:textColor="#4CAF50"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="12dp"
            android:background="?attr/selectableItemBackground"
            android:drawableStart="@android:drawable/ic_menu_help"
            android:drawablePadding="8dp" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#33FFFFFF" android:layout_marginVertical="16dp" />

        <LinearLayout
            android:id="@+id/btn_sleep_timer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:background="?attr/selectableItemBackground">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="おやすみタイマー / Sleep Timer"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />
            <TextView
                android:id="@+id/tv_sleep_timer_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OFF"
                android:textColor="#BBBBBB" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#33FFFFFF" android:layout_marginVertical="16dp" />

        <TextView
            android:id="@+id/btn_battery_optimization"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="バッテリー制限の解除 / Disable Battery Restrictions"
            android:textColor="#FF9800"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="12dp"
            android:background="?attr/selectableItemBackground"
            android:drawableStart="@android:drawable/ic_lock_idle_low_battery"
            android:drawablePadding="8dp" />

</LinearLayout>
